# ─────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────
# Local development (Docker Postgres). When the app runs INSIDE the
# docker-compose network the host is "db"; from your host machine it is
# "localhost". docker-compose injects the in-network value automatically.
DATABASE_URL=postgresql://ramen:ramen@localhost:5432/cocaramen

# Production (Supabase): copy the "Connection string" → "URI" (use the
# pooled connection on port 6543 for serverless / Vercel).
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────────────────────────
# AUTH_MODE controls how login works:
#   dev      -> local credentials login (no cloud needed). Great for local dev.
#   supabase -> Supabase Auth (production). Requires the keys below.
AUTH_MODE=dev

# Used only when AUTH_MODE=dev. Comma-separated list of email:password pairs.
DEV_AUTH_USERS=operator@cocaramen.local:ramen1234,chef@cocaramen.local:ramen1234

# Used only when AUTH_MODE=supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# GEOCODING / ROUTING (Geoapify — free key, no card)
# ─────────────────────────────────────────────────────────────
# Used for address autocomplete + delivery route geometry. When empty, the app
# falls back to the public Photon/OSRM services (less accurate in Argentina).
# Get a free key at https://myprojects.geoapify.com
GEOAPIFY_API_KEY=

# ─────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
